# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# Required: Groq API key for llama-3.3-70b-versatile
# Get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: URL of the local Qwen Python inference server (qwen/qwen_server.py)
# Default is http://localhost:8000 — only set this if you're running the server on a different port
QWEN_API_URL=http://127.0.0.1:8000

# Optional: URL of the local BERT Python inference server (bert-from-scratch/bert_server.py)
# Default is http://localhost:8001 — only set this if you're running the server on a different port
BERT_API_URL=http://127.0.0.1:8001
